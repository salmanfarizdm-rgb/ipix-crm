# ═══════════════════════════════════════════════════════
#  IPIX CRM — Backend Environment Variables
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════

# Server
PORT=3004
NODE_ENV=development

# Supabase
# Get these from https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# JWT Secret (for signing auth tokens)
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# Anthropic (for AI Reports feature)
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here

# CORS — set to your frontend URL in production
# In development, all localhost origins are allowed automatically
FRONTEND_URL=http://localhost:3003

# For Railway deployment, these are set automatically:
# PORT — Railway injects this
# NODE_ENV=production
