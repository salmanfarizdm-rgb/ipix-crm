{
  "name": "ipix-crm",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"retail,sales\" -c \"cyan,magenta\" \"npm run dev:retail\" \"npm run dev:sales\"",
    "dev:retail": "vite --config vite.config.js",
    "dev:sales": "vite --config vite.config.sales.js",
    "build:retail": "vite build --config vite.config.js",
    "build:sales": "vite build --config vite.config.sales.js",
    "preview:retail": "vite preview --config vite.config.js",
    "preview:sales": "vite preview --config vite.config.sales.js"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0",
    "zustand": "^4.5.0",
    "axios": "^1.6.7",
    "date-fns": "^3.3.1",
    "react-hot-toast": "^2.4.1",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.1.4",
    "tailwindcss": "^3.4.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "concurrently": "^8.2.2"
  }
}
