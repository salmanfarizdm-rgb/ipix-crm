# ═══════════════════════════════════════════════════════
#  IPIX CRM — Frontend Environment Variables
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════

# Backend API URL
# Development: point to local backend
VITE_API_URL=http://localhost:3004/api

# Production (Vercel): set this in Vercel dashboard → Settings → Environment Variables
# VITE_API_URL=https://your-backend.railway.app/api

# Ngrok sharing (set automatically by share.sh):
# VITE_API_URL=https://xxxx-xx-xx-xxx-xx.ngrok-free.app/api
